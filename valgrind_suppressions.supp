# This file is a suppression list for valgrind (dynamic analysis tool). Use this file as such:
# valgrind --suppressions=valgrind_suppressions.supp  ./Tests

{
   Backtrace
   Memcheck:Param
   openat(filename)
   ...
   fun:backtrace_open
   ...
}

{
   ThreadStart
   Memcheck:Leak
   match-leak-kinds: possible
   ...
   fun:_ZN7AThread5startEv
   ...
}

{
   IDontknowWhatIsThis
   Memcheck:Leak
   match-leak-kinds: possible
   fun:malloc
   fun:RegisterStubCallbacks
   ...
}

{
   fontconfig
   Memcheck:Leak
   match-leak-kinds: definite
   fun:malloc
   ...
   fun:XML_ParseBuffer
   ...
}

{
   fontconfig
   Memcheck:Leak
   match-leak-kinds: definite
   fun:calloc
   ...
   fun:XML_ParseBuffer
   ...
}

{
   dlopen
   Memcheck:Leak
   match-leak-kinds: possible
   ...
   fun:do_dlopen
   ...
}

{
   <GTK_Init_Leaks>
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:malloc
   obj:*/libgtk-3*
}

{
   <OpenGL_Leaks>
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:malloc
   obj:*/libGL*
}

{
   <Signal_Slot_Reachable>
   Memcheck:Leak
   match-leak-kinds: reachable
   fun:_Znwm
   ...
   fun:*SignalSlot*
}
